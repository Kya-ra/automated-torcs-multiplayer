FROM python:3.13-slim
WORKDIR /torcs

# System dependencies (Wine, X11, GPU, QtWayland)
RUN dpkg --add-architecture i386 \
    && apt-get update && apt-get install -y \
        wine wine32 \
        x11-xserver-utils \
        libgl1-mesa-dri \
        libgl1 \
        mesa-utils \
        qtwayland5 \
        pulseaudio \
        libpulse0 libpulse0:i386 \
        tmux \
        python3 \
    && rm -rf /var/lib/apt/lists/*

# Python dependencies including PyQt6
COPY requirements.txt /tmp/requirements.txt
RUN pip install --no-cache-dir -r /tmp/requirements.txt

# Copy GUI + scripts + assets
COPY launch_menu /torcs/launch_menu
COPY torcs /torcs/torcs
COPY Scripts /torcs/Scripts
COPY launch.sh /torcs/launch.sh
COPY containerrun.py /torcs/containerrun.py
COPY launch_menu/menu_multiplayer.py /torcs/menu_multiplayer.py

# Make launch.sh executable
RUN chmod +x /torcs/launch.sh

# Environment defaults
ENV QT_QPA_PLATFORM=wayland
ENV LIBGL_ALWAYS_INDIRECT=0
ENV PULSE_SERVER=unix:/run/user/1000/pulse/native

# Start the GUI automatically
CMD ["python3", "menu_multiplayer.py"]
