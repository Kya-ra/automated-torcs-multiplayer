FROM python:3.13-slim

WORKDIR /torcs

# ------------------------------
# 1️⃣ Enable 32-bit libs and install dependencies
# ------------------------------
RUN dpkg --add-architecture i386 \
    && apt-get update \
    && apt-get install -y --no-install-recommends \
        wine \
        wine32 \
        tmux \
        x11-xserver-utils \
        wayland-protocols \
        libgl1-mesa-dri \
        libgl1-mesa-dri:i386 \
        libglu1-mesa \
        libglu1-mesa:i386 \
        libegl-mesa0 \
        libegl-mesa0:i386 \
        libgles2-mesa-dev \
        libgles2-mesa-dev:i386 \
        libx11-6 \
        libx11-6:i386 \
        libx11-xcb1 \
        libxcb-cursor0 \
        libxcb-icccm4 \
        libxcb-image0 \
        libxcb-keysyms1 \
        libxcb-randr0 \
        libxcb-render0 \
        libxcb-render-util0 \
        libxcb-shape0 \
        libxcb-shm0 \
        libxcb-sync1 \
        libxcb-xfixes0 \
        libxcb-xinerama0 \
        libxcb-xkb1 \
        libxext6 \
        libxrender1 \
        libxrandr2 \
        libxi6 \
        libsm6 \
        libice6 \
        libfontconfig1 \
        libdbus-1-3 \
        libxkbcommon0 \
        libxkbcommon-x11-0 \
        mesa-utils \
        pulseaudio \
        libpulse0 \
        libpulse0:i386 \
        weston \
        wl-clipboard \
        qtwayland5 \
    && rm -rf /var/lib/apt/lists/*

# ------------------------------
# 2️⃣ Python dependencies
# ------------------------------
COPY requirements.txt /tmp/requirements.txt
RUN pip3 install --no-cache-dir -r /tmp/requirements.txt

# ------------------------------
# 3️⃣ TORCS scripts & files
# ------------------------------
COPY launch.sh .
COPY containerrun.py .
RUN chmod +x launch.sh
COPY gym_torcs /torcs/gym_torcs
COPY torcs /torcs/torcs
COPY launch_menu /torcs/launch_menu
COPY Scripts /torcs/Scripts

# ------------------------------
# 4️⃣ Environment defaults
# ------------------------------
ENV QT_QPA_PLATFORM=wayland
ENV LIBGL_ALWAYS_INDIRECT=0

# ------------------------------
# 5️⃣ Default command
# ------------------------------
CMD ["python3", "containerrun.py"]